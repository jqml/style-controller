{
  "name": "style-controller",
  "version": "0.1.0",
  "description": "Manage reusable Obsidian style profiles, path overrides, and visual settings through a native settings interface.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "styles",
    "profiles"
  ],
  "author": "JQML",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.1",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.2"
  }
}
